{
  "name": "@bdd-workflow/harness-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "server": "tsx server/index.ts",
    "serve": "npm run build && npm run server",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:storybook": "HOME=.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 vitest run --project=storybook --reporter=default --reporter=junit --outputFile.junit=\"${STORYBOOK_JUNIT_FILE:-test-results/storybook-junit.xml}\"",
    "build": "tsc --noEmit && vite build",
    "storybook": "HOME=.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6007 --host 127.0.0.1",
    "build-storybook": "HOME=.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "source-index": "node tools/source-index.mjs",
    "validate": "npm run typecheck && npm run test && npm run test:storybook && npm run build-storybook && npm run source-index"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tanstack/react-query": "^5.80.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.4",
    "@storybook/react-vite": "^10.4.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.60.0",
    "postcss": "^8.5.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.7"
  }
}
