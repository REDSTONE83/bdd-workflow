{
  "name": "bdd-workflow-front-end",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "api:generate": "node tools/generate-api-client.mjs",
    "api:check": "node tools/generate-api-client.mjs --check",
    "source-index": "node tools/source-index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "E2E_RESULTS_FILE=test-results/e2e-results.json playwright test",
    "e2e:partial": "playwright test",
    "storybook": "HOME=.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --host 127.0.0.1",
    "build-storybook": "HOME=.cache/storybook STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "preview": "vite preview --host 127.0.0.1",
    "validate": "npm run api:check && npm run typecheck && npm run lint && npm run test && npm run build && npm run source-index",
    "validate:full": "npm run validate && npm run build-storybook && npm run e2e"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.15.1",
    "shadcn": "^4.8.1",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.47.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.7"
  }
}
